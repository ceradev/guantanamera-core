# --- SERVER CONFIGURATION ---
PORT=8000
DATABASE_URL="postgresql://your_db_user:your_db_password@postgres:5432/guantanamera_core"

# Auth
ADMIN_API_KEY=your-secure-api-key
JWT_SECRET=your-secure-jwt-secret-at-least-32-chars
BCRYPT_ROUNDS=12

# Monitoring
SENTRY_DSN=""

# Seed
ADMIN_EMAIL=admin@guantanamera.com
ADMIN_PASSWORD=default-password

# --- CLIENT CONFIGURATION ---
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_ADMIN_API_KEY=your-admin-api-key
NEXT_PUBLIC_SENTRY_DSN=""

# --- DATABASE (POSTGRES) CONFIGURATION ---
POSTGRES_DB=guantanamera_core
POSTGRES_USER=your_db_user
POSTGRES_PASSWORD=your_db_password
