PORT=8000
DATABASE_URL="postgresql://user:password@localhost:5432/guantanamera_core"

# Auth
ADMIN_API_KEY=your-secure-api-key
JWT_SECRET=your-secure-jwt-secret-at-least-32-chars
BCRYPT_ROUNDS=12

# Monitoring
SENTRY_DSN=""

# Seed
ADMIN_EMAIL=admin@guantanamera.com
ADMIN_PASSWORD=default-password

# Rate Limit
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100
